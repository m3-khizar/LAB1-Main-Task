#include "mbed.h"   

int main()
{
    // Initialise all three LEDs as digital output pins
    DigitalOut led1(LED1);
    DigitalOut led2(LED2);
    DigitalOut led3(LED3);

    // Counter to track number of ticks elapsed
    int counter = 0;

    while (true)
    {
        // LED2 toggles every 2 ticks = 500ms (twice as fast as LED1)
        if (counter % 2 == 0) led2 = !led2;

        // LED1 toggles every 4 ticks = 1000ms (base speed)
        if (counter % 4 == 0) led1 = !led1;

        // LED3 toggles every 8 ticks = 2000ms (half as fast as LED1)
        if (counter % 8 == 0) led3 = !led3;

        counter++;  // Increment counter each tick

        // Base tick = 250ms (smallest unit of time used)
        ThisThread::sleep_for(250ms);
    }
}
